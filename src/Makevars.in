PKG_CPPFLAGS = -I.
PKG_CFLAGS   = -pthread
PKG_CXXFLAGS = -DARMA_64BIT_WORD=1 @RCPP_PARALLEL_CXXFLAGS@ -DRCPP_PARALLEL_USE_TBB=1 $(SHLIB_OPENMP_CXXFLAGS)
PKG_LIBS     = @RCPP_PARALLEL_LIBS@ -Wl,-rpath,@RCPP_PARALLEL_LIBDIR@ $(LAPACK_LIBS) $(BLAS_LIBS) $(FLIBS) $(SHLIB_OPENMP_CXXFLAGS) @OMP_LIBS@
CXX_STD      = CXX17
